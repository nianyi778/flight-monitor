# ━━━ Telegram Bot ━━━
TG_BOT_TOKEN=your-bot-token
TG_CHAT_ID=your-private-chat-id
# 群聊 Chat ID（可选，逗号分隔，如 -100123,-100456）
# TG_GROUP_IDS=

# ━━━ TiDB / MySQL 数据库 ━━━
DB_HOST=your-tidb-host
DB_PORT=4000
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_NAME=flight_monitor

# ━━━ 调度 ━━━
# 基础检查间隔（秒），实际按倒计时分频：<30天1h / 30-90天3h / >90天6h
CHECK_INTERVAL=3600
# 价格提醒推送间隔（秒）
PUSH_INTERVAL=3600

# ━━━ 代理（可选，住宅代理可降低被检测风险）━━━
# PROXY_URL=http://user:pass@host:port

# ━━━ 携程 DOM 抓取（Chrome CDP）━━━
# docker-compose 已内置 chrome sidecar，无需手动配置
# 若使用宿主机 Chrome，改为: CTRIP_CDP_PORT=host.docker.internal:9222
# CTRIP_CDP_PORT=chrome:9222

# ━━━ LetsFG（多航司聚合搜索）━━━
# 无 key 则走本地 connectors（免费）；有 key 走云端搜索（更稳定）
# 注册: https://api.letsfg.co/api/v1/agents/register
LETSFG_API_KEY=your-letsfg-api-key
LETSFG_MODE=cloud
# LETSFG_TIMEOUT=90

# ━━━ MCP Server（供外部 AI Agent 调用）━━━
MCP_ENABLED=true
MCP_PORT=8081
# MCP_AUTH_TOKEN=your-secret-token

# ━━━ Bot 频率限制 ━━━
# BOT_RATE_LIMIT_PER_MINUTE=10
