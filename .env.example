# LLM API
LLM_BASE_URL=https://sub2api.nianyi.dpdns.org/v1
LLM_API_KEY=sk-your-key-here
LLM_MODEL=gpt-4o

# Telegram
TG_BOT_TOKEN=your-bot-token
TG_CHAT_ID=your-chat-id

# 航班参数
OUTBOUND_DATE=2026-09-18
RETURN_DATE=2026-09-27
BUDGET_TOTAL=1500

# 去程19:00后出发
OUTBOUND_DEPART_AFTER=19
# 回程凌晨06:00前落地
RETURN_ARRIVE_BEFORE=6

# 检查间隔（秒），默认3600=1小时
CHECK_INTERVAL=3600
# 通知推送间隔（秒）
PUSH_INTERVAL=60
